  <property name="styleSheet">
   <string notr="true">
  /* Main Background with a subtle gradient */
  QWidget {
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #0b1220, stop:1 #060913);
      color: #e2e8f0;
      font-family: &quot;Segoe UI&quot;, sans-serif;
  }

  /* Elevated Card with a brilliant top highlight */
  QFrame#card {
      background-color: #172033;
      border-radius: 12px;
      border: 1px solid #2a3448;
      border-top: 2px solid #3b82f6; /* Adds a modern 'accent line' to the top of the card */
  }

  /* Header */
  QLabel#headerLabel {
      color: #ffffff;
      font-size: 24px;
      font-weight: 900;
      letter-spacing: 1px;
  }

  /* Dynamic Buttons */
  QPushButton {
      background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #3b82f6, stop:1 #2563eb);
      color: #ffffff;
      font-weight: bold;
      padding: 12px;
      border-radius: 8px;
      font-size: 14px;
      border: 1px solid #1d4ed8;
  }

  QPushButton:hover {
      background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #60a5fa, stop:1 #3b82f6);
      border: 1px solid #93c5fd;
  }

  /* The Tactile Click Effect */
  QPushButton:pressed {
      background-color: #1e3a8a;
      padding-top: 14px; /* Pushes the text down slightly */
      padding-bottom: 10px;
  }

  /* Input Fields (For the Login Screen) */
  QLineEdit, QComboBox {
      background-color: #0f172a;
      color: #ffffff;
      padding: 10px;
      border: 2px solid #1e293b;
      border-radius: 6px;
      selection-background-color: #3b82f6;
  }

  /* Glowing Focus State for Inputs */
  QLineEdit:focus, QComboBox:focus {
      border: 2px solid #3b82f6;
      background-color: #1e293b;
  }
  </string>
